# Lotus PM — Environment Variables Template
# Copy to .env.local for local development. NEVER commit .env.local.
# Production values stored in AWS Secrets Manager.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://lotus:lotus@localhost:5432/lotus_pm"

# ─── Auth (NextAuth.js) ───────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Generate: openssl rand -base64 32
ALLOW_CREDENTIALS_AUTH="true"  # Enable credentials login outside dev (set in staging/prod)

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used for magic-link URLs, provider portal invitations, and participant approval links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# S3 bucket for invoice/document storage (REQ-011: ap-southeast-2 only)
# AWS_S3_BUCKET is the primary bucket used by documents, email-send, and replace-pdf.
# S3_BUCKET_INVOICES is an optional override used by email-ingest for invoice attachments.
AWS_S3_BUCKET=""
S3_BUCKET_INVOICES=""

# SQS queue URLs
SQS_QUEUE_INVOICE_PROCESSING=""
SQS_QUEUE_NOTIFICATIONS=""

# EventBridge bus name
EVENTBRIDGE_BUS_NAME="lotus-pm-events"

# AWS Bedrock — AI invoice processing (REQ-007)
# Model ID for Claude on Bedrock. Used by the AI invoice processor.
BEDROCK_MODEL_ID="au.anthropic.claude-haiku-4-5-20251001-v1:0"

# AWS Cognito (optional — credentials provider used in dev)
COGNITO_CLIENT_ID=""
COGNITO_CLIENT_SECRET=""
COGNITO_ISSUER=""

# ─── SMS — ClickSend ──────────────────────────────────────────────────────────
# ClickSend account credentials for SMS delivery.
# Sign up at https://www.clicksend.com and find credentials under API Credentials.
# REQ-011: ClickSend is an Australian provider — SMS content only, no data stored offshore.
CLICKSEND_USERNAME=""      # Your ClickSend account username (email)
CLICKSEND_API_KEY=""       # Your ClickSend API key (not account password)

# ─── Email — AWS SES ──────────────────────────────────────────────────────────
SES_FROM_EMAIL="noreply@planmanager.lotusassist.com.au"

# ─── Email Invoice Ingestion (REQ-024) ────────────────────────────────────────
# Pre-shared secret for POST /api/email-ingest (internal SQS worker auth).
# Generate: openssl rand -base64 32
EMAIL_INGEST_SECRET=""
# Domain verified in SES for inbound email. Must have MX record pointing to
# inbound-smtp.ap-southeast-2.amazonaws.com before the CDK rule set can receive mail.
# Emails sent to invoices@<SES_INBOUND_EMAIL_DOMAIN> will be processed.
SES_INBOUND_EMAIL_DOMAIN=""

# ─── Xero ─────────────────────────────────────────────────────────────────────
# Create a Xero app at https://developer.xero.com/app/manage
# Set OAuth2 redirect URI to: {NEXTAUTH_URL}/api/xero/callback
# REQ-019/REQ-023: Two-way Xero sync (invoices → bills, payments, reconciliation)
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
XERO_REDIRECT_URI="http://localhost:3000/api/xero/callback"  # Update for staging/production

# ─── ABN Lookup — Australian Business Register ──────────────────────────────
# GUID from ABR Web Services registration.
# Register free at: https://abr.business.gov.au/Tools/WebServiceRegistration
# Used by provider onboarding to auto-populate ABN details. Optional — gracefully
# returns null if not configured.
ABR_GUID=""

# ─── Provider Portal ────────────────────────────────────────────────────────
# Email address for PM notifications when a new provider registers.
# Falls back to director@lotusassist.com.au if not set.
PM_NOTIFICATION_EMAIL="director@lotusassist.com.au"

# ─── Webhooks ───────────────────────────────────────────────────────────────
# Secret for validating WordPress onboarding webhooks.
# Generate: openssl rand -base64 32
WORDPRESS_WEBHOOK_SECRET=""

# ─── Token Secrets ──────────────────────────────────────────────────────────
# Signing secrets for participant-facing verification links.
# Generate each with: openssl rand -base64 32
# WARNING: hardcoded dev defaults exist — MUST be set in staging/production.
STATEMENT_TOKEN_SECRET=""
APPROVAL_TOKEN_SECRET=""

# ─── Automation Cron Runner ───────────────────────────────────────────────────
# Secret token for POST /api/automation/cron — called by GitHub Actions every 5 minutes.
# Generate with: openssl rand -base64 32
CRON_SECRET=
