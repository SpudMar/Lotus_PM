// ─────────────────────────────────────────────
// FLAGS MODULE — WS-F3
// REQ-017: Flag/Hold system for participants and providers.
// ─────────────────────────────────────────────

enum FlagSeverity {
  ADVISORY   // informational — shown as yellow banner, does NOT block invoice approval
  BLOCKING   // shown as red banner — requires explicit PM acknowledgment before approval
}

model CrmFlag {
  id            String        @id @default(cuid())
  severity      FlagSeverity  @default(ADVISORY)
  reason        String        // free text description of the flag

  createdAt     DateTime      @default(now())
  createdById   String
  createdBy     CoreUser      @relation("FlagCreatedBy", fields: [createdById], references: [id])

  // Attach to participant OR provider (exactly one must be set)
  participantId String?
  participant   CrmParticipant? @relation(fields: [participantId], references: [id])
  providerId    String?
  provider      CrmProvider?    @relation(fields: [providerId], references: [id])

  // Resolution
  resolvedAt    DateTime?
  resolvedById  String?
  resolvedBy    CoreUser?     @relation("FlagResolvedBy", fields: [resolvedById], references: [id])
  resolveNote   String?

  deletedAt     DateTime?     // soft delete

  @@index([participantId, resolvedAt])
  @@index([providerId, resolvedAt])
  @@map("crm_flags")
}

// ─────────────────────────────────────────────
// NDIS PRICE GUIDE MODULE — WS-F1
// REQ-014: NDIS Price Guide 2025-26 compliance
// ─────────────────────────────────────────────

enum PricingRegion {
  NON_REMOTE
  REMOTE
  VERY_REMOTE
}

model NdisPriceGuideVersion {
  id            String    @id @default(cuid())
  label         String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  importedAt    DateTime  @default(now())
  importedById  String
  importedBy    CoreUser  @relation("PriceGuideImportedBy", fields: [importedById], references: [id])
  items         NdisSupportItem[]

  @@index([effectiveFrom])
  @@map("ndis_price_guide_versions")
}

model NdisSupportItem {
  id                      String                @id @default(cuid())
  versionId               String
  version                 NdisPriceGuideVersion @relation(fields: [versionId], references: [id])
  itemNumber              String
  name                    String
  categoryCode            String
  categoryCodePace        String
  categoryName            String
  categoryNamePace        String
  registrationGroupNumber String
  registrationGroupName   String
  unitType                String
  itemType                String?
  quotable                Boolean               @default(false)
  priceStandardCents      Int?
  priceRemoteCents        Int?
  priceVeryRemoteCents    Int?
  allowNonFaceToFace      Boolean               @default(false)
  allowProviderTravel     Boolean               @default(false)
  allowShortNoticeCancel  Boolean               @default(false)
  allowNdiaReports        Boolean               @default(false)
  allowIrregularSil       Boolean               @default(false)
  gstCode                 String?

  @@unique([versionId, itemNumber])
  @@index([itemNumber])
  @@index([categoryCode])
  @@index([categoryCodePace])
  @@map("ndis_support_items")
}


// --------------------------------------------------
// SA BUDGET ALLOCATION -- WS-F6
// Internal tracking of budget committed from plan lines to service agreements.
// Under PACE, service bookings are deprecated -- this is PM-internal only.
// One budget line can be split across multiple SAs; one SA can draw from multiple lines.
// --------------------------------------------------

model SaBudgetAllocation {
  id                 String             @id @default(cuid())
  serviceAgreementId String
  serviceAgreement   SaServiceAgreement @relation(fields: [serviceAgreementId], references: [id])
  budgetLineId       String
  budgetLine         PlanBudgetLine     @relation(fields: [budgetLineId], references: [id])
  allocatedCents     Int                // partial amount from this budget line for this SA
  note               String?            // e.g. "OT sessions Aug-Dec 2025"
  createdAt          DateTime           @default(now())
  createdById        String
  createdBy          CoreUser           @relation(fields: [createdById], references: [id])

  @@unique([serviceAgreementId, budgetLineId])
  @@index([budgetLineId])
  @@index([serviceAgreementId])
  @@map("sa_budget_allocations")
}

// --------------------------------------------------
// INVOICE ITEM PATTERN LEARNING -- WS-F4
// Tracks observed support code usage per provider/participant/category
// to suggest codes when invoices arrive without them.
// --------------------------------------------------

model InvItemPattern {
  id            String   @id @default(cuid())
  providerId    String
  provider      CrmProvider      @relation(fields: [providerId], references: [id])
  participantId String?  // null = applies to all participants for this provider
  participant   CrmParticipant?  @relation(fields: [participantId], references: [id])
  categoryCode  String
  itemNumber    String
  occurrences   Int      @default(1)
  lastSeenAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([providerId, participantId, categoryCode, itemNumber])
  @@index([providerId, categoryCode])
  @@map("inv_item_patterns")
}

// --------------------------------------------------
// PM FEE BILLING MODULE
// Plan management fees charged to participants monthly.
// Category 14 support items claimed to NDIS.
// --------------------------------------------------

enum PmFeeFrequency {
  MONTHLY
  PER_INVOICE
  ONE_OFF
}

enum PmFeeChargeStatus {
  PENDING    // charge created, no claim yet
  CLAIMED    // ClmClaim generated
  PAID       // payment received
  WAIVED     // manually waived by PM
}

// PM Fee Schedule -- defines standard fees the PM charges
model PmFeeSchedule {
  id               String           @id @default(cuid())
  name             String           // e.g. "Monthly Plan Management Fee"
  supportItemCode  String           // NDIS code e.g. "14_033_0127_8_3"
  description      String?
  rateCents        Int              // standard rate in cents
  frequency        PmFeeFrequency   @default(MONTHLY)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  overrides        PmFeeOverride[]
  charges          PmFeeCharge[]

  @@map("pm_fee_schedules")
}

// Per-participant rate override
model PmFeeOverride {
  id              String         @id @default(cuid())
  feeScheduleId  String
  feeSchedule    PmFeeSchedule  @relation(fields: [feeScheduleId], references: [id])
  participantId  String
  participant    CrmParticipant @relation(fields: [participantId], references: [id])
  rateCents      Int            // override rate for this participant
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  @@unique([feeScheduleId, participantId])
  @@map("pm_fee_overrides")
}

// Individual fee charge record
model PmFeeCharge {
  id              String            @id @default(cuid())
  feeScheduleId  String
  feeSchedule    PmFeeSchedule     @relation(fields: [feeScheduleId], references: [id])
  participantId  String
  participant    CrmParticipant    @relation(fields: [participantId], references: [id])
  periodStart    DateTime
  periodEnd      DateTime
  amountCents    Int
  status         PmFeeChargeStatus @default(PENDING)
  claimId        String?           // linked ClmClaim once generated
  generatedAt    DateTime          @default(now())
  generatedById  String?
  notes          String?
  deletedAt      DateTime?

  @@unique([feeScheduleId, participantId, periodStart])
  @@map("pm_fee_charges")
}

// --------------------------------------------------
// PARTICIPANT STATEMENTS MODULE
// Financial statements sent to participants.
// --------------------------------------------------

enum StatementFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  NONE
}

enum StatementDelivery {
  EMAIL
  SMS
  MAIL
}

model ParticipantStatement {
  id                   String             @id @default(cuid())
  participantId        String
  participant          CrmParticipant     @relation(fields: [participantId], references: [id])
  periodStart          DateTime
  periodEnd            DateTime
  generatedAt          DateTime           @default(now())
  sentAt               DateTime?
  deliveryMethod       StatementDelivery  @default(EMAIL)
  s3Key                String?            // PDF/HTML stored in S3
  totalInvoicedCents   Int                // cents
  totalClaimedCents    Int                // cents
  totalPaidCents       Int                // cents
  budgetRemainingCents Int                // cents
  lineItems            Json               // StatementLineItem[]
  createdById          String
  deletedAt            DateTime?

  @@index([participantId])
  @@index([periodStart, periodEnd])
  @@map("participant_statements")
}
