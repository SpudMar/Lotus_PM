  @@map("sa_service_agreements")
}

model SaRateLine {
  id              String    @id @default(cuid())
  agreementId     String
  categoryCode    String
  categoryName    String
  supportItemCode String?
  supportItemName String?
  agreedRateCents Int
  maxQuantity     Decimal?
  unitType        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agreement       SaServiceAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@map("sa_rate_lines")
}

// ─────────────────────────────────────────────
// EMAIL TEMPLATES MODULE — REQ-032
// Customisable templates with merge fields,
// fixed/variable attachments, form links.
// WS5 — AWS SES sending.
// ─────────────────────────────────────────────

enum EmailTemplateType {
  WELCOME_PACK
  SERVICE_AGREEMENT
  INVOICE_NOTIFICATION
  CLAIM_STATUS
  BUDGET_REPORT
  APPROVAL_REQUEST
  CUSTOM
}

model NotifEmailTemplate {
  id                          String            @id @default(cuid())
  name                        String            @unique
  type                        EmailTemplateType
  subject                     String
  bodyHtml                    String            @db.Text
  bodyText                    String?           @db.Text
  mergeFields                 Json              @default("[]") // array of field names like ["participantName", "providerName"]
  fixedAttachmentIds          Json              @default("[]") // array of DocDocument IDs
  supportsVariableAttachment  Boolean           @default(false)
  variableAttachmentDescription String?
  includesFormLink            Boolean           @default(false)
  formLinkUrl                 String?
  isActive                    Boolean           @default(true)
  createdById                 String
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt

  createdBy   CoreUser         @relation("TemplateCreatedBy", fields: [createdById], references: [id])
  sentEmails  NotifSentEmail[]

  @@map("notif_email_templates")
}

model NotifSentEmail {
  id              String       @id @default(cuid())
  templateId      String?
  toEmail         String
  toName          String?
  subject         String
  bodyHtml        String       @db.Text
  sesMessageId    String?
  status          NotifStatus  // reuse existing enum
  errorMessage    String?
  sentAt          DateTime?
  participantId   String?
  attachmentKeys  Json         @default("[]") // S3 keys of attachments sent
  triggeredById   String?
  createdAt       DateTime     @default(now())

  template        NotifEmailTemplate? @relation(fields: [templateId], references: [id])
  participant     CrmParticipant?     @relation(fields: [participantId], references: [id])

  @@index([templateId])
  @@index([participantId])
  @@index([status])
  @@index([createdAt])
  @@map("notif_sent_emails")
}

enum ParticipantOnboardingStatus {
  DRAFT
  PENDING_PLAN
  COMPLETE
}

enum CrmIngestSource {
  MANUAL
  WORDPRESS
  API
}

// ─────────────────────────────────────────────
// FUND QUARANTINE MODULE — Earmarked Budget per Provider (REQ-030)
// ─────────────────────────────────────────────

enum FqStatus {
  ACTIVE
  RELEASED
  EXPIRED
}

enum QuarantineLimitType {
  SOFT
  HARD
}

model FqQuarantine {
  id                  String    @id @default(cuid())
  serviceAgreementId  String?
  budgetLineId        String
  providerId          String
  supportItemCode     String?
  quarantinedCents    Int
  usedCents           Int       @default(0)
  fundingPeriodId     String?   // FK deferred — WS3 (DEC-003)
  status              FqStatus  @default(ACTIVE)
  limitType           QuarantineLimitType @default(SOFT)
  notes               String?
  createdById         String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  serviceAgreement    SaServiceAgreement? @relation(fields: [serviceAgreementId], references: [id])
  budgetLine          PlanBudgetLine      @relation(fields: [budgetLineId], references: [id])
  provider            CrmProvider         @relation(fields: [providerId], references: [id])
